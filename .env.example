# LLM Gateway (LiteLLM, OpenRouter, or any OpenAI-compatible API)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=your-api-key

# Model for write gate scoring and fact extraction
GATE_MODEL=deepseek-chat

# Graphiti knowledge graph (optional — works without it)
GRAPHITI_URL=http://localhost:8000

# Embedding server (any OpenAI-compatible embeddings endpoint)
EMBEDDING_URL=http://localhost:8100/v1/embeddings
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=384

# Write gate threshold (0.0-1.0, lower = more permissive)
GATE_THRESHOLD=0.55

# Cross-encoder reranking
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Write-time fact extraction
FACT_EXTRACTION_ENABLED=true

# Graphiti timeout (seconds)
GRAPHITI_RECALL_TIMEOUT=10.0

# Reconsolidation (v6) — memories enrich on recall
RECONSOLIDATION_ENABLED=true
RECONSOLIDATION_MIN_ACCESS=3
RECONSOLIDATION_MAX_COUNT=5
RECONSOLIDATION_COOLDOWN_HOURS=24
