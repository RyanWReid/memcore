# MemCore Configuration
# Copy to .env and fill in your values

# LiteLLM gateway (any OpenAI-compatible API)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=your-api-key-here

# Gate model (cheap, fast, reliable JSON output)
GATE_MODEL=deepseek-chat

# PostgreSQL (docker-compose default works out of the box)
POSTGRES_URL=postgresql://memcore:memcore@memcore-db:5432/memcore

# Embeddings server (local nomic-embed-text)
EMBEDDING_URL=http://localhost:8100/v1/embeddings
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=384

# Graphiti knowledge graph (optional — works without it)
GRAPHITI_URL=http://localhost:8000

# MemCore API
MEMCORE_URL=http://localhost:8020
MCP_HOST=0.0.0.0
MCP_PORT=8020

# Features (all enabled by default)
RERANKER_ENABLED=true
FACT_EXTRACTION_ENABLED=true
RECONSOLIDATION_ENABLED=true

# Benchmark (only needed for running LongMemEval)
BENCHMARK_MODEL=deepseek-chat
